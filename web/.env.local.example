# Turso DB (Vercel production)
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-token

# Local development (comment out TURSO_DATABASE_URL to use this)
# Uses file:local.db automatically

# Authentication (optional, SHA-256 hash of password)
AUTH_PASSWORD_HASH=

# Poller API key (shared secret between Vercel and PC)
POLLER_API_KEY=
